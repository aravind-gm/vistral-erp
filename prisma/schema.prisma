// Vistral ERP - Complete Prisma Schema
// Textile Manufacturing ERP for Tiruppur, India

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  OWNER
  GENERAL_MANAGER
  MERCHANDISER
  PURCHASE
  STORE
  PRODUCTION
  ACCOUNTS
  QUALITY
  ADMIN
}

enum OrderStatus {
  ENQUIRY
  QUOTATION_SENT
  PO_RECEIVED
  CONFIRMED
  IN_PRODUCTION
  DISPATCHED
  INVOICED
  PAYMENT_RECEIVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum YarnProcurementStatus {
  DRAFT
  APPROVED
  ORDERED
  PARTIAL_RECEIVED
  RECEIVED
  CANCELLED
}

enum ProductionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

enum GSTType {
  CGST_SGST
  IGST
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VIEW
  EXPORT
  LOGIN
  LOGOUT
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

// ============================================================
// COMPANY
// ============================================================

model Company {
  id            String    @id @default(cuid())
  name          String
  legalName     String
  gstin         String    @unique
  pan           String    @unique
  addressLine1  String
  addressLine2  String?
  city          String
  state         String
  pincode       String
  country       String    @default("India")
  phone         String
  email         String
  website       String?
  logoUrl       String?
  bankName      String?
  bankBranch    String?
  bankAccount   String?
  bankIfsc      String?
  upiId         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  createdBy     String
  updatedBy     String

  @@map("companies")
}

// ============================================================
// AUTH - USERS, SESSIONS, ACCOUNTS (Better Auth)
// ============================================================

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  emailVerified  Boolean   @default(false)
  image          String?
  phone          String?
  role           UserRole  @default(MERCHANDISER)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  createdBy      String?
  updatedBy      String?

  sessions       Session[]
  accounts       Account[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  createdOrders  Order[]        @relation("OrderCreatedBy")
  updatedOrders  Order[]        @relation("OrderUpdatedBy")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ============================================================
// ROLES & PERMISSIONS
// ============================================================

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  createdBy   String
  updatedBy   String

  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  module      String
  action      String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  roles       RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================
// CUSTOMERS
// ============================================================

model Customer {
  id           String    @id @default(cuid())
  code         String    @unique
  name         String
  contactPerson String?
  email        String?
  phone        String
  altPhone     String?
  gstin        String?
  pan          String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  pincode      String
  country      String    @default("India")
  creditLimit  Decimal   @default(0) @db.Decimal(15, 2)
  creditDays   Int       @default(30)
  isActive     Boolean   @default(true)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  createdBy    String
  updatedBy    String

  orders       Order[]
  invoices     Invoice[]

  @@map("customers")
}

// ============================================================
// SUPPLIERS / VENDORS
// ============================================================

model Supplier {
  id           String    @id @default(cuid())
  code         String    @unique
  name         String
  contactPerson String?
  email        String?
  phone        String
  altPhone     String?
  gstin        String?
  pan          String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  pincode      String
  country      String    @default("India")
  bankName     String?
  bankBranch   String?
  bankAccount  String?
  bankIfsc     String?
  supplierType String    // YARN, DYES, CHEMICALS, ACCESSORIES, FABRIC, etc.
  isActive     Boolean   @default(true)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  createdBy    String
  updatedBy    String

  yarnProcurements YarnProcurement[]
  purchaseOrders   PurchaseOrder[]

  @@map("suppliers")
}

// ============================================================
// PRODUCTS / ITEMS MASTER
// ============================================================

model YarnType {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  count       String    // e.g., "30s", "40s"
  composition String    // e.g., "100% Cotton", "60/40 PC"
  ply         Int       @default(1)
  unit        String    @default("KG")
  hsn         String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdBy   String
  updatedBy   String

  yarnInventories  YarnInventory[]
  procurementItems YarnProcurementItem[]
  orderYarnPlans   OrderYarnPlan[]

  @@map("yarn_types")
}

model FabricType {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  gsm         Decimal?  @db.Decimal(8, 2)
  composition String?
  width       Decimal?  @db.Decimal(8, 2)
  unit        String    @default("KG")
  hsn         String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdBy   String
  updatedBy   String

  greyFabrics  GreyFabric[]
  orderDetails OrderDetail[]

  @@map("fabric_types")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id              String      @id @default(cuid())
  orderNo         String      @unique
  customerId      String
  companyName     String?
  customer        Customer    @relation(fields: [customerId], references: [id])
  buyerOrderNo    String?
  styleNo         String?
  styleName       String?
  season          String?
  category        String?     // T-SHIRT, POLO, HOODIE, etc.
  quantity        Int
  unit            String      @default("PCS")
  status          OrderStatus @default(ENQUIRY)
  orderDate       DateTime    @default(now())
  deliveryDate    DateTime?
  shipmentDate    DateTime?
  portOfLoading   String?
  portOfDestination String?
  paymentTerms    String?
  incoterms       String?
  currency        String      @default("INR")
  exchangeRate    Decimal     @default(1) @db.Decimal(10, 4)
  remarks         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String
  createdByUser   User        @relation("OrderCreatedBy", fields: [createdBy], references: [id])
  updatedByUser   User        @relation("OrderUpdatedBy", fields: [updatedBy], references: [id])

  orderDetails    OrderDetail[]
  orderCosting    OrderCosting?
  yarnPlans       OrderYarnPlan[]
  yarnProcurements YarnProcurement[]
  productionBatches ProductionBatch[]
  invoices        Invoice[]
  documents       Document[]

  @@map("orders")
}

model OrderDetail {
  id           String     @id @default(cuid())
  orderId      String
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fabricTypeId String?
  fabricType   FabricType? @relation(fields: [fabricTypeId], references: [id])
  color        String
  size         String?
  styleNo      String?
  xs           Int        @default(0)
  s            Int        @default(0)
  m            Int        @default(0)
  l            Int        @default(0)
  xl           Int        @default(0)
  xxl          Int        @default(0)
  xxxl         Int        @default(0)
  quantity     Int
  unitPrice    Decimal    @db.Decimal(12, 4)
  amount       Decimal    @db.Decimal(15, 2)
  gsm          Decimal?   @db.Decimal(8, 2)
  composition  String?
  remarks      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  createdBy    String
  updatedBy    String

  @@map("order_details")
}

// ============================================================
// ORDER COSTING
// ============================================================

model OrderCosting {
  id                  String   @id @default(cuid())
  orderId             String   @unique
  order               Order    @relation(fields: [orderId], references: [id])
  yarnCost            Decimal  @default(0) @db.Decimal(15, 2)
  knittingCost        Decimal  @default(0) @db.Decimal(15, 2)
  dyeingCost          Decimal  @default(0) @db.Decimal(15, 2)
  printingCost        Decimal  @default(0) @db.Decimal(15, 2)
  compactingCost      Decimal  @default(0) @db.Decimal(15, 2)
  cuttingCost         Decimal  @default(0) @db.Decimal(15, 2)
  stitchingCost       Decimal  @default(0) @db.Decimal(15, 2)
  packingCost         Decimal  @default(0) @db.Decimal(15, 2)
  overheadPercent     Decimal  @default(10) @db.Decimal(5, 2)
  profitPercent       Decimal  @default(15) @db.Decimal(5, 2)
  totalCostPerPc      Decimal  @default(0) @db.Decimal(12, 4)
  sellingPricePerPc   Decimal  @default(0) @db.Decimal(12, 4)
  totalOrderValue     Decimal  @default(0) @db.Decimal(15, 2)
  remarks             String?
  approvedBy          String?
  approvedAt          DateTime?
  costingDetails      Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String
  updatedBy           String

  @@map("order_costings")
}

// ============================================================
// YARN PLANNING
// ============================================================

model OrderYarnPlan {
  id             String    @id @default(cuid())
  orderId        String
  order          Order     @relation(fields: [orderId], references: [id])
  yarnTypeId     String
  yarnType       YarnType  @relation(fields: [yarnTypeId], references: [id])
  requiredQty    Decimal   @db.Decimal(12, 3)
  wastagePercent Decimal   @default(5) @db.Decimal(5, 2)
  totalRequired  Decimal   @db.Decimal(12, 3)
  procuredQty    Decimal   @default(0) @db.Decimal(12, 3)
  remarks        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  createdBy      String
  updatedBy      String

  @@map("order_yarn_plans")
}

// ============================================================
// YARN PROCUREMENT
// ============================================================

model YarnProcurement {
  id          String                  @id @default(cuid())
  poNo        String                  @unique
  orderId     String?
  order       Order?                  @relation(fields: [orderId], references: [id])
  supplierId  String
  supplier    Supplier                @relation(fields: [supplierId], references: [id])
  status      YarnProcurementStatus   @default(DRAFT)
  poDate      DateTime                @default(now())
  expectedDate DateTime?
  totalAmount Decimal                 @default(0) @db.Decimal(15, 2)
  remarks     String?
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  deletedAt   DateTime?
  createdBy   String
  updatedBy   String

  items       YarnProcurementItem[]
  receipts    YarnReceipt[]

  @@map("yarn_procurements")
}

model YarnProcurementItem {
  id              String          @id @default(cuid())
  procurementId   String
  procurement     YarnProcurement @relation(fields: [procurementId], references: [id], onDelete: Cascade)
  yarnTypeId      String
  yarnType        YarnType        @relation(fields: [yarnTypeId], references: [id])
  quantity        Decimal         @db.Decimal(12, 3)
  unit            String          @default("KG")
  unitPrice       Decimal         @db.Decimal(12, 4)
  amount          Decimal         @db.Decimal(15, 2)
  hsn             String?
  gstPercent      Decimal         @default(5) @db.Decimal(5, 2)
  receivedQty     Decimal         @default(0) @db.Decimal(12, 3)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("yarn_procurement_items")
}

// ============================================================
// YARN INVENTORY (STORE)
// ============================================================

model YarnInventory {
  id              String    @id @default(cuid())
  yarnTypeId      String
  yarnType        YarnType  @relation(fields: [yarnTypeId], references: [id])
  lotNo           String?
  supplierId      String?
  currentStock    Decimal   @default(0) @db.Decimal(12, 3)
  reservedStock   Decimal   @default(0) @db.Decimal(12, 3)
  availableStock  Decimal   @default(0) @db.Decimal(12, 3)
  unit            String    @default("KG")
  location        String?
  reorderLevel    Decimal   @default(0) @db.Decimal(12, 3)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String
  updatedBy       String

  transactions    YarnTransaction[]

  @@map("yarn_inventories")
}

model YarnTransaction {
  id              String        @id @default(cuid())
  inventoryId     String
  inventory       YarnInventory @relation(fields: [inventoryId], references: [id])
  type            String        // RECEIPT, ISSUE, RETURN, ADJUSTMENT
  referenceType   String?       // PROCUREMENT, PRODUCTION, etc.
  referenceId     String?
  quantity        Decimal       @db.Decimal(12, 3)
  balanceAfter    Decimal       @db.Decimal(12, 3)
  remarks         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String
  updatedBy       String

  @@map("yarn_transactions")
}

model YarnReceipt {
  id              String          @id @default(cuid())
  receiptNo       String          @unique
  procurementId   String
  procurement     YarnProcurement @relation(fields: [procurementId], references: [id])
  receiptDate     DateTime        @default(now())
  vehicleNo       String?
  dcNo            String?
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("yarn_receipts")
}

// ============================================================
// PRODUCTION BATCH (TRACKS FULL PRODUCTION LIFECYCLE)
// ============================================================

model ProductionBatch {
  id             String           @id @default(cuid())
  batchNo        String           @unique
  orderId        String
  order          Order            @relation(fields: [orderId], references: [id])
  quantity       Int
  status         ProductionStatus @default(PENDING)
  startDate      DateTime?
  completedDate  DateTime?
  remarks        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  createdBy      String
  updatedBy      String

  knitting       KnittingProcess?
  greyFabric     GreyFabric?
  dyeingProcess  DyeingProcess?
  heatsetting    HeatsettingProcess?
  centering      CenteringProcess?
  printingProcess PrintingProcess?
  compacting     CompactingProcess?
  bioWash        BioWashProcess?
  checking       CheckingProcess?
  cutting        CuttingProcess?
  stitching      StitchingProcess?
  packing        PackingProcess?
  dispatch       Dispatch?

  @@map("production_batches")
}

// ============================================================
// KNITTING
// ============================================================

model KnittingProcess {
  id              String          @id @default(cuid())
  batchId         String          @unique
  batch           ProductionBatch @relation(fields: [batchId], references: [id])
  machineNo       String?
  gaugeNo         String?
  diameter        Decimal?        @db.Decimal(8, 2)
  gsm             Decimal?        @db.Decimal(8, 2)
  yarnIssued      Decimal         @default(0) @db.Decimal(12, 3)
  fabricProduced  Decimal         @default(0) @db.Decimal(12, 3)
  wastage         Decimal         @default(0) @db.Decimal(12, 3)
  status          ProductionStatus @default(PENDING)
  startDate       DateTime?
  completedDate   DateTime?
  operatorName    String?
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("knitting_processes")
}

// ============================================================
// GREY FABRIC
// ============================================================

model GreyFabric {
  id              String          @id @default(cuid())
  batchId         String          @unique
  batch           ProductionBatch @relation(fields: [batchId], references: [id])
  fabricTypeId    String?
  fabricType      FabricType?     @relation(fields: [fabricTypeId], references: [id])
  rollCount       Int             @default(0)
  totalWeight     Decimal         @default(0) @db.Decimal(12, 3)
  gsm             Decimal?        @db.Decimal(8, 2)
  width           Decimal?        @db.Decimal(8, 2)
  inspectionStatus String         @default("PENDING") // PENDING, PASSED, FAILED
  inspectedBy     String?
  inspectedAt     DateTime?
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("grey_fabrics")
}

// ============================================================
// DYEING
// ============================================================

model DyeingProcess {
  id              String          @id @default(cuid())
  batchId         String          @unique
  batch           ProductionBatch @relation(fields: [batchId], references: [id])
  dyeHouseRef     String?
  isInHouse       Boolean         @default(true)
  subcontractorId String?
  color           String
  shade           String?
  recipe          String?
  fabricIn        Decimal         @default(0) @db.Decimal(12, 3)
  fabricOut       Decimal         @default(0) @db.Decimal(12, 3)
  status          ProductionStatus @default(PENDING)
  startDate       DateTime?
  completedDate   DateTime?
  costPerKg       Decimal?        @db.Decimal(10, 4)
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("dyeing_processes")
}

// ============================================================
// PRINTING
// ============================================================

model PrintingProcess {
  id              String          @id @default(cuid())
  batchId         String          @unique
  batch           ProductionBatch @relation(fields: [batchId], references: [id])
  printType       String?         // SCREEN, DIGITAL, SUBLIMATION, etc.
  designRef       String?
  isInHouse       Boolean         @default(false)
  subcontractorId String?
  fabricIn        Decimal         @default(0) @db.Decimal(12, 3)
  fabricOut       Decimal         @default(0) @db.Decimal(12, 3)
  status          ProductionStatus @default(PENDING)
  startDate       DateTime?
  completedDate   DateTime?
  costPerPc       Decimal?        @db.Decimal(10, 4)
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("printing_processes")
}

// ============================================================
// COMPACTING
// ============================================================

model CompactingProcess {
  id              String          @id @default(cuid())
  batchId         String          @unique
  batch           ProductionBatch @relation(fields: [batchId], references: [id])
  fabricIn        Decimal         @default(0) @db.Decimal(12, 3)
  fabricOut       Decimal         @default(0) @db.Decimal(12, 3)
  shrinkage       Decimal         @default(0) @db.Decimal(5, 2)
  status          ProductionStatus @default(PENDING)
  startDate       DateTime?
  completedDate   DateTime?
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("compacting_processes")
}

// ============================================================
// CHECKING / QC
// ============================================================

model CheckingProcess {
  id              String          @id @default(cuid())
  batchId         String          @unique
  batch           ProductionBatch @relation(fields: [batchId], references: [id])
  checkedQty      Int             @default(0)
  passedQty       Int             @default(0)
  rejectedQty     Int             @default(0)
  defectDetails   String?
  status          ProductionStatus @default(PENDING)
  startDate       DateTime?
  completedDate   DateTime?
  inspectorName   String?
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("checking_processes")
}

// ============================================================
// CUTTING
// ============================================================

model CuttingProcess {
  id              String          @id @default(cuid())
  batchId         String          @unique
  batch           ProductionBatch @relation(fields: [batchId], references: [id])
  pliesCount      Int             @default(0)
  fabricUsed      Decimal         @default(0) @db.Decimal(12, 3)
  cutPieces       Int             @default(0)
  wastage         Decimal         @default(0) @db.Decimal(12, 3)
  markerEfficiency Decimal?       @db.Decimal(5, 2)
  status          ProductionStatus @default(PENDING)
  startDate       DateTime?
  completedDate   DateTime?
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("cutting_processes")
}

// ============================================================
// STITCHING
// ============================================================

model StitchingProcess {
  id              String          @id @default(cuid())
  batchId         String          @unique
  batch           ProductionBatch @relation(fields: [batchId], references: [id])
  receivedQty     Int             @default(0)
  stitchedQty     Int             @default(0)
  rejectedQty     Int             @default(0)
  lineNo          String?
  supervisorName  String?
  costPerPc       Decimal?        @db.Decimal(10, 4)
  status          ProductionStatus @default(PENDING)
  startDate       DateTime?
  completedDate   DateTime?
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("stitching_processes")
}

// ============================================================
// PACKING
// ============================================================

model PackingProcess {
  id              String          @id @default(cuid())
  batchId         String          @unique
  batch           ProductionBatch @relation(fields: [batchId], references: [id])
  packedQty       Int             @default(0)
  cartons         Int             @default(0)
  grossWeight     Decimal         @default(0) @db.Decimal(12, 3)
  netWeight       Decimal         @default(0) @db.Decimal(12, 3)
  packingType     String?         // BULK, INNER, INDIVIDUAL
  status          ProductionStatus @default(PENDING)
  startDate       DateTime?
  completedDate   DateTime?
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("packing_processes")
}

// ============================================================
// DISPATCH
// ============================================================

model Dispatch {
  id              String          @id @default(cuid())
  dispatchNo      String          @unique
  batchId         String          @unique
  batch           ProductionBatch @relation(fields: [batchId], references: [id])
  dispatchDate    DateTime        @default(now())
  vehicleNo       String?
  lrNo            String?
  lrDate          DateTime?
  courier         String?
  trackingNo      String?
  cartons         Int             @default(0)
  grossWeight     Decimal         @default(0) @db.Decimal(12, 3)
  netWeight       Decimal         @default(0) @db.Decimal(12, 3)
  deliveryAddress String?
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("dispatches")
}

// ============================================================
// PURCHASE ORDERS (ACCESSORIES, MATERIALS)
// ============================================================

model PurchaseOrder {
  id          String    @id @default(cuid())
  poNo        String    @unique
  supplierId  String
  supplier    Supplier  @relation(fields: [supplierId], references: [id])
  poDate      DateTime  @default(now())
  expectedDate DateTime?
  status      String    @default("DRAFT") // DRAFT, APPROVED, RECEIVED, CANCELLED
  totalAmount Decimal   @default(0) @db.Decimal(15, 2)
  remarks     String?
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdBy   String
  updatedBy   String

  items       PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id          String        @id @default(cuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  itemName    String
  itemCode    String?
  description String?
  quantity    Decimal       @db.Decimal(12, 3)
  unit        String
  unitPrice   Decimal       @db.Decimal(12, 4)
  amount      Decimal       @db.Decimal(15, 2)
  hsn         String?
  gstPercent  Decimal       @default(18) @db.Decimal(5, 2)
  receivedQty Decimal       @default(0) @db.Decimal(12, 3)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdBy   String
  updatedBy   String

  @@map("purchase_order_items")
}

// ============================================================
// INVOICES
// ============================================================

model Invoice {
  id              String        @id @default(cuid())
  invoiceNo       String        @unique
  orderId         String?
  order           Order?        @relation(fields: [orderId], references: [id])
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id])
  invoiceDate     DateTime      @default(now())
  dueDate         DateTime?
  status          InvoiceStatus @default(DRAFT)
  gstType         GSTType       @default(CGST_SGST)
  subtotal        Decimal       @default(0) @db.Decimal(15, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(15, 2)
  taxableAmount   Decimal       @default(0) @db.Decimal(15, 2)
  cgst            Decimal       @default(0) @db.Decimal(15, 2)
  sgst            Decimal       @default(0) @db.Decimal(15, 2)
  igst            Decimal       @default(0) @db.Decimal(15, 2)
  totalAmount     Decimal       @default(0) @db.Decimal(15, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(15, 2)
  balanceAmount   Decimal       @default(0) @db.Decimal(15, 2)
  paymentStatus   PaymentStatus @default(PENDING)
  remarks         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String

  items           InvoiceItem[]
  payments        Payment[]

  @@map("invoices")
}

model InvoiceItem {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description   String
  hsn           String?
  quantity      Decimal  @db.Decimal(12, 3)
  unit          String
  unitPrice     Decimal  @db.Decimal(12, 4)
  amount        Decimal  @db.Decimal(15, 2)
  gstPercent    Decimal  @default(5) @db.Decimal(5, 2)
  cgstAmount    Decimal  @default(0) @db.Decimal(15, 2)
  sgstAmount    Decimal  @default(0) @db.Decimal(15, 2)
  igstAmount    Decimal  @default(0) @db.Decimal(15, 2)
  totalAmount   Decimal  @db.Decimal(15, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String
  updatedBy     String

  @@map("invoice_items")
}

// ============================================================
// PAYMENTS
// ============================================================

model Payment {
  id              String        @id @default(cuid())
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])
  paymentDate     DateTime      @default(now())
  amount          Decimal       @db.Decimal(15, 2)
  paymentMode     String        // CASH, CHEQUE, NEFT, RTGS, UPI
  referenceNo     String?
  bankName        String?
  remarks         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String
  updatedBy       String

  @@map("payments")
}

// ============================================================
// DOCUMENTS / ATTACHMENTS
// ============================================================

model Document {
  id            String    @id @default(cuid())
  name          String
  type          String    // PO, INVOICE, PACKING_LIST, TEST_REPORT, etc.
  url           String
  size          Int
  mimeType      String
  orderId       String?
  order         Order?    @relation(fields: [orderId], references: [id])
  uploadedBy    String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("documents")
}

// ============================================================
// AUDIT LOGS
// ============================================================

model AuditLog {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  action      AuditAction
  module      String
  recordId    String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  type        NotificationType @default(INFO)
  title       String
  message     String
  link        String?
  isRead      Boolean          @default(false)
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ============================================================
// HEATSETTING
// ============================================================

model HeatsettingProcess {
  id              String          @id @default(cuid())
  batchId         String          @unique
  batch           ProductionBatch @relation(fields: [batchId], references: [id])
  tempCelsius     Decimal?        @db.Decimal(8, 2)
  speedMpm        Decimal?        @db.Decimal(8, 2)
  fabricIn        Decimal         @default(0) @db.Decimal(12, 3)
  fabricOut       Decimal         @default(0) @db.Decimal(12, 3)
  status          ProductionStatus @default(PENDING)
  startDate       DateTime?
  completedDate   DateTime?
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("heatsetting_processes")
}

// ============================================================
// CENTERING
// ============================================================

model CenteringProcess {
  id              String          @id @default(cuid())
  batchId         String          @unique
  batch           ProductionBatch @relation(fields: [batchId], references: [id])
  widthInches     Decimal?        @db.Decimal(8, 2)
  fabricIn        Decimal         @default(0) @db.Decimal(12, 3)
  fabricOut       Decimal         @default(0) @db.Decimal(12, 3)
  status          ProductionStatus @default(PENDING)
  startDate       DateTime?
  completedDate   DateTime?
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("centering_processes")
}

// ============================================================
// BIO WASH
// ============================================================

model BioWashProcess {
  id              String          @id @default(cuid())
  batchId         String          @unique
  batch           ProductionBatch @relation(fields: [batchId], references: [id])
  enzymeUsed      String?
  fabricIn        Decimal         @default(0) @db.Decimal(12, 3)
  fabricOut       Decimal         @default(0) @db.Decimal(12, 3)
  status          ProductionStatus @default(PENDING)
  startDate       DateTime?
  completedDate   DateTime?
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String

  @@map("bio_wash_processes")
}
